{
  "manifest_version": 3,
  "name": "Hide YouTube Shorts",
  "version": "1.0",
  "description": "Hides the Shorts button and Shorts section from YouTube",
  "permissions": ["activeTab"],
  "host_permissions": ["*://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
